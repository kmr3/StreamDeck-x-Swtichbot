{
  "name": "streamdeck-switchbot-v11",
  "version": "1.0.0",
  "description": "Unofficial SwitchBot API v1.1 plugin for Elgato Stream Deck.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && rollup -c && node scripts/copy-static.mjs",
    "test": "vitest --run",
    "lint": "eslint .",
    "format": "prettier . --write",
    "generate:assets": "node scripts/generate-assets.mjs"
  },
  "keywords": [
    "streamdeck",
    "switchbot",
    "plugin"
  ],
  "author": "Example",
  "license": "MIT",
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "@elgato/utils": "^0.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.10.1",
    "ajv": "^8.17.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.1",
    "rollup": "^4.53.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.13"
  },
  "engines": {
    "node": ">=24"
  }
